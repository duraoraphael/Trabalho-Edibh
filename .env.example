# ============================================================================
# VARIÁVEIS DE AMBIENTE - FLUXO DE EQUIPAMENTOS
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores reais

# AMBIENTE (development | production)
ENVIRONMENT=development

# JWT - CHAVE SECRETA (MUDE ISSO EM PRODUÇÃO!)
JWT_SECRET=sua-chave-secreta-super-segura-aqui-com-32-caracteres-minimo

# JWT - EXPIRAÇÃO (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SHAREPOINT (Deixe em branco se não usar SharePoint)
SHAREPOINT_SITE_ID=
SHAREPOINT_ONE_DRIVE_ID=
SHAREPOINT_LIST_NAME=RelatoriosTecnicos
SHAREPOINT_USER_LIST_NAME=Usuarios
SHAREPOINT_LIBRARY_ID=

# MICROSOFT GRAPH API (Deixe em branco se não usar)
GRAPH_TENANT_ID=seu-tenant-id
GRAPH_CLIENT_ID=seu-client-id
GRAPH_CLIENT_SECRET=seu-client-secret
GRAPH_SCOPE=https://graph.microsoft.com/.default

# URL DO FRONTEND (para CORS)
FRONTEND_URL=http://localhost:3000

# SEGURANÇA
PASSWORD_SALT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=120

# ============================================================================
# FRONTEND - VARIÁVEIS REACT
# ============================================================================

# URL DA API BACKEND
REACT_APP_API_URL=http://localhost:8000/api

# DEV ONLY - pula a tela de login no frontend (NUNCA usar em produção)
# Chamadas à API que exigem token ainda retornarão 401.
REACT_APP_SKIP_AUTH=false

# ============================================================================
# DEPLOYMENT - CONFIGURAÇÕES
# ============================================================================

# Para Railway/Render:
# ENVIRONMENT=production
# JWT_SECRET=gerar-chave-aleatoria-segura
# FRONTEND_URL=https://seu-dominio.vercel.app
# REACT_APP_API_URL=https://seu-backend.railway.app/api
